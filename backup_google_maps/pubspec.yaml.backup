name: geo_social_app
description: "A new Flutter project."
publish_to: 'none'
version: 1.0.0+1

environment:
  sdk: '>=3.2.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.8
  google_maps_flutter: ^2.5.3
  geolocator: ^12.0.0
  permission_handler: ^11.3.1
  cloud_firestore: ^4.17.5
  firebase_core: ^2.32.0
  geoflutterfire2: ^2.3.6
  custom_info_window: ^1.0.1
  provider: ^6.1.1 # Adding provider for state management if needed, good practice

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
